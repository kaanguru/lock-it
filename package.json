{
  "name": "lock-it",
  "version": "1.0.2",
  "private": true,
  "description": " Offline hardware and software asset management tool for IT professionals.",
  "keywords": [
    "dexie",
    "superforms",
    "sveltekit"
  ],
  "license": "GPL-3.0-only",
  "author": "CEM KAAN KOSALI",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "vite dev",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "preview": "vite preview",
    "test": "npm run test:pl && npm run test:unit",
    "test:pl": "playwright test",
    "test:unit": "vitest",
    "ver": "npm version patch -m 'patched'"
  },
  "dependencies": {
    "@floating-ui/dom": "1.6.3",
    "@vincjo/datatables": "^1.14.5",
    "dexie": "^4.0.4",
    "iconify-icon": "^2.1.0"
  },
  "devDependencies": {
    "@anatine/zod-mock": "^3.13.4",
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.43.1",
    "@skeletonlabs/skeleton": "^2.9.1",
    "@skeletonlabs/tw-plugin": "^0.4.0",
    "@sveltejs/adapter-static": "^3.0.1",
    "@sveltejs/kit": "^2.5.6",
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "@tailwindcss/forms": "0.5.7",
    "@tailwindcss/typography": "^0.5.12",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.37.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "prettier-plugin-svelte": "^3.2.3",
    "svelte": "^4.2.15",
    "svelte-check": "^3.6.9",
    "sveltekit-superforms": "^2.12.5",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.9",
    "vite-plugin-tailwind-purgecss": "^0.3.1",
    "vitest": "^1.5.0",
    "zod": "^3.22.4"
  }
}
