{
	"name": "lock-it",
	"version": "1.0.2",
	"private": true,
	"author": "CEM KAAN KOSALI",
	"description": " Offline hardware and software asset management tool for IT professionals.",
	"keywords": [
		"dexie",
		"superforms",
		"sveltekit"
	],
	"license": "GPL-3.0-only",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "npm run test:pl && npm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:pl": "playwright test",
		"test:unit": "vitest",
		"ver": "npm version patch -m 'patched'"
	},
	"devDependencies": {
		"@playwright/test": "^1.43.0",
		"@skeletonlabs/skeleton": "2.8.0",
		"@skeletonlabs/tw-plugin": "0.3.1",
		"@sveltejs/adapter-auto": "^3.2.0",
		"@sveltejs/adapter-static": "^3.0.1",
		"@sveltejs/kit": "^2.5.5",
		"@sveltejs/vite-plugin-svelte": "^3.0.2",
		"@tailwindcss/forms": "0.5.7",
		"@tailwindcss/typography": "0.5.10",
		"@types/eslint": "8.56.2",
		"@types/node": "20.11.19",
		"@typescript-eslint/eslint-plugin": "^7.5.0",
		"@typescript-eslint/parser": "^7.5.0",
		"autoprefixer": "^10.4.19",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.35.1",
		"postcss": "^8.4.38",
		"prettier": "^3.2.5",
		"prettier-plugin-svelte": "^3.2.2",
		"svelte": "^4.2.12",
		"svelte-check": "^3.6.9",
		"sveltekit-superforms": "^2.12.2",
		"tailwindcss": "^3.4.3",
		"tslib": "^2.6.2",
		"typescript": "^5.4.4",
		"vite": "^5.2.8",
		"vite-plugin-tailwind-purgecss": "0.2.0",
		"vitest": "^1.4.0",
		"zod": "^3.22.4"
	},
	"type": "module",
	"dependencies": {
		"@anatine/zod-mock": "^3.13.4",
		"@faker-js/faker": "^8.4.1",
		"@floating-ui/dom": "1.6.3",
		"@vincjo/datatables": "^1.14.5",
		"dexie": "4.0.1-beta.9",
		"iconify-icon": "^2.0.0"
	}
}
